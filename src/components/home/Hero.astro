---
import { Image } from "astro:assets";
import { Icon } from 'astro-icon/components';
import { site } from "../../data/site";


const {
  title,
  description,
  primaryButton,
  secondaryButton,
  image,
  badge,
  proof,
  whatsApp
} = Astro.props;
---

<section class="relative w-full overflow-hidden">

  <!-- IMAGE FULL WIDTH -->
  <div class="relative w-full h-[80vh] md:h-[90vh]">

   <Image
      src={image.src}
      alt={image.alt}
      class="w-full h-full 
      object-cover
    object-[80%_center] 
    md:object-center
    bg-white"
      loading="eager"
    />

    <!-- GRADIENT POUR LISIBILITÉ -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- TEXTE EN HAUT DE L'IMAGE -->
    <div class="absolute top-10  w-full px-6 md:px-16 pb-10 md:pb-14 text-white">

      {badge && (
        <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm mb-4">
          {badge}
        </div>
      )}

      <h1 class="text-3xl md:text-7xl leading-tight font-serif max-w-1/3">
        {title}
      </h1>
      
    </div>
    <!-- TEXTE EN BAS DE L'IMAGE -->
    <div class="absolute bottom-0  w-full px-6 md:px-16 pb-10 md:pb-14 text-white">

      <p
        class="
          mt-6
          text-sm
          md:text-2xl
          drop-shadow-md

          flex
          flex-col
          md:flex-row

          items-center
          justify-center
          gap-3
          md:gap-6

          text-center
        "
      >

        <!-- Téléphone -->
        <a
          href={`tel:${site.phone}`}
          class="flex items-center gap-2 hover:opacity-80 transition"
        >
          📞
          <span>{site.phone}</span>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${site.email}`}
          class="flex items-center gap-2 hover:opacity-80 transition"
        >
    ✉️      <span>{site.email}</span>
        </a>

        <!-- WhatsApp -->
        <a
          href={`https://wa.me/${site.whatsApp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="
            flex
            items-center
            gap-2
            px-4
            py-2
            text-white
          "
        >
          <Icon name="logos:whatsapp-icon" class="w-5 h-5" />
          <span>WhatsApp</span>
        </a>

      </p>
    </div>

  </div>

  <!-- BOUTONS CENTRÉS SOUS L'IMAGE -->
  <div class="flex flex-col sm:flex-row justify-center gap-4 py-10 bg-white">

    <a
      href={primaryButton.link}
      class="bg-black text-white px-16 py-3 rounded-lg font-medium hover:opacity-90 transition"
    >
      {primaryButton.text}
    </a>

    <a
      href={secondaryButton.link}
      class="border border-stone-300 px-16 py-3 rounded-lg font-medium hover:bg-stone-100 transition"
    >
      {secondaryButton.text}
    </a>

    

  </div>

</section>