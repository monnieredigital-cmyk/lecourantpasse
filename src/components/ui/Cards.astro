---
import { Image } from "astro:assets";

const { card } = Astro.props;
---

<article
  class="
    rounded-2xl
    overflow-hidden
    bg-white
    shadow-md
    hover:shadow-xl
    transition
    duration-300
  "
>

  <Image
    src={card.image}
    alt={card.title}
    class="w-full h-56 object-cover"
    widths={[400, 800]}
  />

  <div class="p-5">

    <h3
      class="
        text-xl
        font-serif
        mb-3
      "
    >
      {card.title}
    </h3>

    <p
      class="
        text-stone-600
        leading-relaxed
      "
    >
      {card.description}
    </p>
    
<!-- SOURCES -->
    {card.links?.length > 0 && (
      <div class="mt-6 pt-4 border-t border-stone-200">

        <p class="text-sm font-medium text-stone-700 mb-2">
          Sources :
        </p>

        <ul class="space-y-1">

          {card.links.map((link: URL) => (

            <li>
              <a
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                class="
                  text-sm
                  text-amber-700
                  hover:text-amber-800
                  underline
                  break-all
                "
              >
                {new URL(link).hostname}
              </a>
            </li>

          ))}

        </ul>

      </div>
    )}

  </div>

</article>