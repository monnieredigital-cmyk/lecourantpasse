---
import { contactFormData } from "../../data/contactForm";

---

<form
  enctype="multipart/form-data"
  name="contact"
  method="POST"
  data-netlify="true"
  class="
    bg-white
    border
    border-stone-200
    rounded-2xl
    p-6
    md:p-8
    space-y-6
  "
>

  <input
    type="hidden"
    name="form-name"
    value="contact"
  />

  <div>
    <label class="block mb-2 font-medium">
      {contactFormData.labels.requestType}
    </label>

    <select
      id="requestType"
      name="requestType"
      class="
        w-full
        border
        border-stone-300
        rounded-lg
        p-3
      "
    >
      {contactFormData.requestTypes.map((type: { value: string | number | string[] | null | undefined; label: unknown; }) => (
        <option value={type.value}>
          {type.label}
        </option>
      ))}
    </select>
  </div>

  <div
    class="
      grid
      gap-4
      md:grid-cols-2
    "
  >
    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.name}
      </label>

      <input
        type="text"
        name="name"
        required
        class="w-full border border-stone-300 rounded-lg p-3"
      />
    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.email}
      </label>

      <input
        type="email"
        name="email"
        required
        class="w-full border border-stone-300 rounded-lg p-3"
      />
    </div>
  </div>

  <div>
    <label class="block mb-2 font-medium">
      {contactFormData.labels.phone}
    </label>

    <input
      type="tel"
      name="phone"
      class="w-full border border-stone-300 rounded-lg p-3"
    />
  </div>

  <!-- Champs devis -->
  <div
    id="quoteFields"
    class="hidden space-y-6"
  >

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.buildingType}
      </label>

      <select
        name="buildingType"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.buildingTypes.map((item: any) => (
          <option>{item}</option>
        ))}
      </select>
    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.serviceType}
      </label>

      <select
        name="serviceType"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.serviceTypes.map((item: any) => (
          <option>{item}</option>
        ))}
      </select>
    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.electricalIssues}
      </label>

      <select
        name="electricalIssues"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.electricalIssuesOptions.map((item: any) => (
          <option>{item}</option>
        ))}
      </select>
    </div>
    
    
    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.panelAge}
      </label>

      <select
        name="panelAge"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.propertyAgeOptions.map((item: any) => (
          <option>{item}</option>
        ))}
      </select>
    </div>

    <div
      class="
        grid
        gap-4
        md:grid-cols-2
      "
    >

      

      <label>
        <input type="checkbox" name="upToDateWish" />
        {contactFormData.labels.upToDateWish}
      </label>

      <label>
        <input type="checkbox" name="addWish" />
        {contactFormData.labels.addWish}
      </label>

    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.budget}
      </label>

      <select
        name="budget"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.budgetOptions.map((item: unknown) => (
          <option>{item}</option>
        ))}
      </select>
    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.delay}
      </label>

      <select
        name="budget"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.delayOptions.map((item: unknown) => (
          <option>{item}</option>
        ))}
      </select>
    </div>

   <!--  photos -->
    <label class="block font-medium">
    {contactFormData.labels.photos}
  </label>

  <input
  id="fileInput"
  type="file"
  name="photos"
  multiple
  accept="image/*"
  class="
    block
    w-full
    border
    border-stone-300
    rounded-lg
    p-3
    cursor-pointer
    file:bg-white
    file:text-stone-800
    file:border
    file:border-stone-300
    file:px-4
    file:py-2
    file:rounded-full
    file:mr-4
    file:cursor-pointer
    hover:file:bg-stone-100
  "
/>

<input
  type="hidden"
  name="photosUrls"
  id="photosUrls"
/>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.descriptions}
      </label>

      <textarea
        name="description"
        rows="6"
        class="w-full border border-stone-300 rounded-lg p-3"
      ></textarea>
    </div>

  </div>

  <!-- Message simple -->
  <div id="messageField">

    <label class="block mb-2 font-medium">
      {contactFormData.labels.message}
    </label>

    <textarea
      name="message"
      rows="6"
      class="w-full border border-stone-300 rounded-lg p-3"
    ></textarea>

  </div>

  <button
    type="submit"
    class="
      w-full
      md:w-auto
      bg-amber-600
      hover:bg-amber-700
      text-white
      px-8
      py-3
      rounded-lg
      transition
    "
  >
    {contactFormData.labels.submit}
  </button>

</form>

<script>
  import { cloudinary } from "../../data/cloudinary";

  // =========================
  // Formulaire devis/contact
  // =========================

  const requestType = document.getElementById("requestType") as HTMLSelectElement | null;
  const quoteFields = document.getElementById("quoteFields");
  const messageField = document.getElementById("messageField");

  function updateForm() {
    const isQuote = requestType?.value === "quote";

    quoteFields?.classList.toggle("hidden", !isQuote);
    messageField?.classList.toggle("hidden", isQuote);
  }

  requestType?.addEventListener("change", updateForm);
  updateForm();

  // =========================
  // Cloudinary
  // =========================

  const form = document.querySelector("form");
  const fileInput = document.getElementById("fileInput") as HTMLInputElement | null;;
  const photosUrlsInput =
    document.getElementById("photosUrls") as HTMLInputElement | null;;

  const CLOUD_NAME = cloudinary.CLOUD_NAME;
  const UPLOAD_PRESET = cloudinary.UPLOAD_PRESET;

  async function uploadImage(file: string | Blob) {
    const formData = new FormData();

    formData.append("file", file);
    formData.append(
      "upload_preset",
      UPLOAD_PRESET
    );

    const response = await fetch(
      `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`,
      {
        method: "POST",
        body: formData,
      }
    );

    if (!response.ok) {
      throw new Error("Erreur upload Cloudinary");
    }

    return response.json();
  }

  // =========================
  // Envoi du formulaire
  // =========================

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    try {
      const files = fileInput?.files;
      const urls = [];

      if (files && files.length > 0) {
        for (const file of files) {
          const result = await uploadImage(file);
          urls.push(result.secure_url);
        }
      }

      if (photosUrlsInput) {
        photosUrlsInput.value = urls.join("\n");
      }

      form.submit();

    } catch (error) {
      console.error(error);

      alert(
        "Une erreur est survenue lors de l'envoi des photos."
      );
    }
  });
</script>