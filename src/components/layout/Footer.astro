---
import { navigation } from "../../data/navigation";
import { site } from "../../data/site";

const year = new Date().getFullYear();
---

<footer
  class="
    bg-stone-900
    border-t
    border-stone-800
    text-stone-300
  "
>

  <div
    class="
      max-w-6xl
      mx-auto
      px-6
      py-12
      grid
      gap-10
      md:grid-cols-3
    "
  >

    <!-- BRAND -->
    <div class="space-y-3">

      <h3 class="text-xl font-serif text-white">
        {site.name}
      </h3>

      <p class="text-stone-400 leading-relaxed">
        {site.tagline}
      </p>

    </div>

    <!-- LINKS -->
    <div class="space-y-3">

      <h4 class="text-white font-semibold">
        Navigation
      </h4>

      <ul class="space-y-2">

        {navigation.map((link) => (
          <li>
            <a
              href={link.href}
              class="hover:text-amber-400 transition"
            >
              {link.label}
            </a>
          </li>
        ))}

      </ul>

    </div>

    <!-- LEGAL -->
    <div class="space-y-3">

      <h4 class="text-white font-semibold">
        Légal
      </h4>

      <ul class="space-y-2">

        <li>
          <a
            href="/mentions-legales"
            class="hover:text-amber-400 transition"
          >
            Mentions légales
          </a>
        </li>

      </ul>

    </div>

  </div>

  <!-- BOTTOM BAR -->
  <div
    class="
      border-t
      border-stone-800
      py-6
      text-center
      text-stone-500
      text-sm
    "
  >

     © {year} {site.name} — Tous droits réservés

  </div>

</footer>
