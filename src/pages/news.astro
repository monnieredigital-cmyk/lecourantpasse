---
import MainLayout from "../layouts/MainLayout.astro";
import Card from "../components/ui/Cards.astro";

import { site } from "../data/site";
import {
    newsPage,
    news
} from "../data/news";
---

<MainLayout
  title={`Activités | ${site.name}`}
  description="Découvrez les meilleures activités autour du Puy du Fou et de la Vendée"
>

  <!-- HERO -->

  <header
    class="
      text-center
      py-12
      md:py-16
      px-4
    "
  >

    <h1
      class="
        text-4xl
        md:text-6xl
        font-serif
        mb-4
      "
    >
      {newsPage.title}
    </h1>

    <p
      class="
        text-stone-600
        max-w-2xl
        mx-auto
      "
    >
      {newsPage.subtitle}
    </p>

  </header>

  <!-- INTRO -->

  <section
    class="
      max-w-3xl
      mx-auto
      px-4
      mb-12
      text-center
    "
  >

    <p
      class="
        text-lg
        text-stone-700
      "
    >
      {newsPage.intro}
    </p>

  </section>

  <!-- CARTES -->

  <main
    class="
      max-w-7xl
      mx-auto
      px-4
      pb-20
    "
  >

    <div
      class="
        grid
        grid-cols-1
        sm:grid-cols-2
        lg:grid-cols-3
        gap-6
      "
    >

      {news.map((news) => (
        <Card card={news} />
      ))}

    </div>

  </main>

</MainLayout>