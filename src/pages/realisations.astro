---
import MainLayout from "../layouts/MainLayout.astro";
import { realisations, realisationPage } from "../data/realisations";
import RealisationCard from "../components/layout/RealisationCard.astro";
import CTA from "../components/ui/CTA.astro";
import { cta } from "../data/cta";
---

<MainLayout
  title={realisationPage.title}
  description={realisationPage.intro}
>

  <header class="text-center py-16 px-6">
    <h1 class="text-4xl md:text-6xl font-serif">
      {realisationPage.title}
    </h1>

    <p class="text-stone-500 mt-6 max-w-3xl mx-auto">
      {realisationPage.intro}
    </p>
  </header>

  <main class="max-w-6xl mx-auto px-6 pb-24">

    <div class="grid grid-cols-1 gap-10">

      {realisations.map((item) => (
        <RealisationCard realisation={item} />
      ))}

    </div>

<!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 pb-20">

    <CTA
      title={cta.title}
      description={cta.description}
      buttonText={cta.buttonText}
      buttonLink={cta.buttonLink}
    />

  </section>

  </main>

</MainLayout>