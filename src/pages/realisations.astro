---
import MainLayout from "../layouts/MainLayout.astro";
import Card from "../components/ui/Cards.astro";
import CTA from "../components/ui/CTA.astro";
import { cta } from "../data/cta";
import { site } from "../data/site";
import {
  realisations,
  realisationPage
} from "../data/realisations";
---

<MainLayout
  title={`Activités | ${site.name}`}
  description="Découvrez les meilleures activités autour du Puy du Fou et de la Vendée"
>

  <!-- HERO -->

  <header
    class="
      text-center
      py-12
      md:py-16
      px-4
    "
  >

    <h1
      class="
        text-4xl
        md:text-6xl
        font-serif
        mb-4
      "
    >
      {realisationPage.title}
    </h1>

    <p
      class="
        text-stone-600
        max-w-2xl
        mx-auto
      "
    >
      {realisationPage.subtitle}
    </p>

  </header>

  <!-- INTRO -->

  <section
    class="
      max-w-3xl
      mx-auto
      px-4
      mb-12
      text-center
    "
  >

    <p
      class="
        text-lg
        text-stone-700
      "
    >
      {realisationPage.intro}
    </p>

  </section>

  <!-- CARTES -->

  <main
    class="
      max-w-7xl
      mx-auto
      px-4
      pb-20
    "
  >

    <div
      class="
        grid
        grid-cols-1
        sm:grid-cols-2
        lg:grid-cols-3
        gap-6
      "
    >

      {realisations.map((realisation) => (
        <Card card = {realisation} />
      ))} 

    </div>

  </main>

    <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 pb-20">

    <CTA
      title={cta.title}
      description={cta.description}
      buttonText={cta.buttonText}
      buttonLink={cta.buttonLink}
    />

  </section>

</MainLayout>